# APM
apm_modules/
.apm/cache/
apm.lock.yaml

# self-host symlinks (scripts/setup-dev.sh で生成、改修者個人の dev 環境)
# 以下は本物ファイルで git tracked なので除外
# - philosophy: 中核思想 skill (改修者向け)
# - release: リリース手順 skill (改修者向け)
# - announce-release: リリース周知テキスト生成 skill (改修者向け)
# - skill-design-style: skill 設計の流儀 skill (改修者向け)
# - harness-verification: harness 検証手順 skill (改修者向け)
# - kanban: 改修バックログかんばん skill (改修者向け)
# - skill-reviewer: skill レビュー subagent (改修者向け)
# - disclosure-guard: 公開前の固有名詞混入ガード skill (改修者向け)
# - disclosure-auditor: 固有名詞混入 監査 subagent (改修者向け)
.claude/skills/*
!.claude/skills/philosophy/
!.claude/skills/release/
!.claude/skills/announce-release/
!.claude/skills/skill-design-style/
!.claude/skills/harness-verification/
!.claude/skills/kanban/
!.claude/skills/disclosure-guard/
.claude/agents/*
!.claude/agents/skill-reviewer.md
!.claude/agents/disclosure-auditor.md

# Local config / env / secrets
.env
.env.*
*.local.*
settings.local.json

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Logs
*.log
