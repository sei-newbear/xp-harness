{
  "request": {
    "method": "POST",
    "urlPath": "/v1/quote",
    "bodyPatterns": [
      { "matchesJsonPath": "$[?(@.origin == '100-0001')]" },
      { "matchesJsonPath": "$[?(@.destination == '060-0001')]" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": { "fee": 1800, "currency": "JPY" }
  }
}
