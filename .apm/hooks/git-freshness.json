{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/.apm/hooks/scripts/git-freshness.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/.apm/hooks/scripts/git-freshness.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/.apm/hooks/scripts/git-freshness.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
